  "Jwt": {
    "TokenDurationMinutes": 30,
    "Issuer": "CitizenHackathon2025API",
    "Audience": "CitizenHackathon2025.Client",
    "RefreshTokenDays": 7
  },
  "Security": {
    "Enabled": false
  },
  "MistralAI": {
    "ApiBaseUrl": "http://127.0.0.1:11434/",
    "Model": "mistral",
    "Temperature": 0.3,
    "TimeoutSeconds": 300
  },
  "ExternalProviders": {
    "OpenWeather": {
      "BaseUrl": "https://api.openweathermap.org",
      "AllowedHosts": [ "api.openweathermap.org" ],
      "RequireHttps": true,
      "TimeoutSeconds": 8,
      "RetryCount": 2,
      "CircuitBreakerFailures": 5,
      "CircuitBreakerDurationSeconds": 60,
      "MaxPayloadBytes": 524288,
      "RateLimitPerMinute": 60,
      "CacheSeconds": 300
    },
    "ODWB": {
      "BaseUrl": "https://www.odwb.be/api/explore/v2.1/catalog/datasets",
      "DatasetId": "217400",
      "RecordsPath": "records",
      "AllowedHosts": [ "www.odwb.be", "odwb.be" ],
      "RequireHttps": true,
      "TimeoutSeconds": 8,
      "RetryCount": 2,
      "CircuitBreakerFailures": 5,
      "CircuitBreakerDurationSeconds": 60,
      "MaxPayloadBytes": 1048576,
      "RateLimitPerMinute": 60,
      "CacheSeconds": 300
    },
    "WallonieAntennaCadastre": {
      "BaseQueryUrl": "https://geoservices.wallonie.be/arcgis/rest/services/INDUSTRIES_SERVICES/ANTENNES/MapServer/0/",
      "AllowedHosts": [ "geoservices.wallonie.be" ],
      "RequireHttps": true,
      "TimeoutSeconds": 10,
      "RetryCount": 2,
      "CircuitBreakerFailures": 5,
      "CircuitBreakerDurationSeconds": 60,
      "MaxPayloadBytes": 2097152,
      "RateLimitPerMinute": 30,
      "CacheSeconds": 3600,
      "PageSize": 2000,
      "ExternalSource": "WALLONIE_CADASTRE"
    },
    "MistralLocal": {
      "BaseUrl": "http://127.0.0.1:11434/",
      "AllowedHosts": [ "127.0.0.1" ],
      "RequireHttps": false,
      "TimeoutSeconds": 60,
      "RetryCount": 0,
      "CircuitBreakerFailures": 3,
      "CircuitBreakerDurationSeconds": 30,
      "MaxPayloadBytes": 1048576,
      "RateLimitPerMinute": 10,
      "CacheSeconds": 0,
      "AllowLoopback": true
    }
  },
  "AntennaCadastre": {
    "Enabled": true,
    "BaseQueryUrl": "https://geoservices.wallonie.be/arcgis/rest/services/INDUSTRIES_SERVICES/ANTENNES/MapServer/0/query",
    "PageSize": 2000,
    "ExternalSource": "WALLONIE_CADASTRE"
  },
  "AntennaArchiveRetention": {
    "RetentionDays": 30,
    "BatchSize": 10000,
    "IntervalHours": 24
  },
  "Moderation": {
    "BannedWords": [
      "fuck",
      "shit",
      "bitch",
      "asshole",
      "idiot",
      "dumb",
      "moron",
      "connard",
      "con",
      "merde",
      "salaud",
      "enculé",
      "pute",
      "abruti",
      "imbécile",
      "non sécurisé"
    ]
  },
  "CriticalAlertRules": {
    "RequiredDistinctReports": 3,
    "WindowMinutes": 5,
    "AlertDurationMinutes": 5
  }
}
































































































