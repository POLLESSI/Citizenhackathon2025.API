      "BatchSizeLimit": 100,
      "Period": "00:00:02"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "ConnectionStrings": {
    "default": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=CitizenHackathon2025Db;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;Column Encryption Setting=Enabled;MultipleActiveResultSets=False;"
  },
  "ConnectionString": "mongodb://localhost:27017",
  "EventHubs": {
    "ConnectionString": "",
    "EventHubName": "",
    "BatchSizeLimit": 100,
    "PeriodSeconds": 2
  },
